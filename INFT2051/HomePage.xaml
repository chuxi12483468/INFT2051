<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="INFT2051.HomePage"
             Title="Home">

    <Grid Padding="30"
          RowDefinitions="Auto,Auto,*,Auto"
          ColumnDefinitions="*,Auto">

        <!-- Settings button -->
        <Button Text="Settings"
                Grid.Row="0"
                Grid.Column="1" />

        <!-- title -->
        <Label Text="My Diary"
               FontSize="32"
               HorizontalOptions="Center"
               Grid.Row="1"
               Grid.ColumnSpan="2" />

        <!-- Recent Diaries -->
        <VerticalStackLayout Grid.Row="2"
                             Grid.ColumnSpan="2"
                             Spacing="15">

            <Label Text="Recent Diaries"
                   FontSize="22"/>

            <!-- occupy the position -->
            <Frame HeightRequest="80"
                   BorderColor="Gray">
                <Label Text="User diary list will appear here"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Frame>

        </VerticalStackLayout>

        <!-- put create diary on the bottom -->
        <Button Text="Create New Diary"
                Grid.Row="3"
                Grid.ColumnSpan="2"
                Margin="0,20,0,0"/>

    </Grid>

</ContentPage>