<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="INFT2051.SettingPage"
             Title="Settings">

    <VerticalStackLayout Padding="30" Spacing="20">

        <Label
            Text="Settings"
            FontSize="32"
            HorizontalOptions="Center"/>

        <!-- PIN modification -->
        <Label Text="PIN Lock"/>

        <Entry x:Name="NewPinEntry"
               Placeholder="Enter new PIN"
               Keyboard="Numeric"
               MaxLength="4"
               IsPassword="True"/>

        <Button Text="Update"
                Clicked="OnUpdatePinClicked"/>

        <!-- Daily Reminder -->
        <Label Text="Daily Reminder"/>

        <Switch x:Name="ReminderSwitch"
                Toggled="OnReminderToggled"/>

        <!-- Export -->
        <Button Text="Export to Text"
                Clicked="OnExportClicked"/>

        <!-- Back -->
        <Button Text="Back"
                Clicked="OnBackClicked"/>

    </VerticalStackLayout>

</ContentPage>